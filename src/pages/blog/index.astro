---
import "@fontsource-variable/inter";
import "@fontsource-variable/space-grotesk";
import "../../styles/global.css";
import { getCollection } from "astro:content";

const sortedPosts = (await getCollection("blog")).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="NoArousal articles about no PMO, flatline, recovery habits, and brain technology loops." />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://noa.farros.co/blog/" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0f1318" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="NoArousal" />
    <meta property="og:title" content="NoArousal Blog" />
    <meta property="og:description" content="Articles about no-PMO recovery, flatline, attention, discipline, and PMO technology loops." />
    <meta property="og:url" content="https://noa.farros.co/blog/" />
    <meta name="twitter:card" content="summary" />
    <title>NoArousal Blog</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="NoArousal home">
        <span class="brand-mark">N</span>
        <span class="brand-text">NoArousal</span>
      </a>
      <button class="menu-toggle" type="button" aria-label="Open menu" aria-controls="primaryNav" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
      <nav class="nav-links" id="primaryNav" aria-label="Primary navigation">
        <span class="menu-label">Menu</span>
        <a href="/">Home</a>
        <a href="/arena/">Arena</a>
        <a href="/blog/">Blog</a>
        <a href="/quotes/">Quotes</a>
      </nav>
    </header>

    <main>
      <section class="blog-hero reveal-on-scroll">
        <p class="badge">Knowledge base</p>
        <h1>NoArousal Blog</h1>
        <p>
          Short, practical articles on PMO recovery, flatline, attention, and the discipline that comes from keeping your streak public.
        </p>
      </section>

      <section class="blog-grid" aria-label="NoArousal articles">
        {sortedPosts.map((post) => (
          <article class="blog-card">
            <a class="blog-card-image" href={`/blog/${post.id}/`} aria-label={`Read ${post.data.title}`}>
              <img src={post.data.image.url} alt={post.data.image.alt} loading="lazy" />
            </a>
            <div class="post-meta">
              <span>{post.data.category}</span>
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })}
              </time>
            </div>
            <h2><a href={`/blog/${post.id}/`}>{post.data.title}</a></h2>
            <p>{post.data.description}</p>
            <div class="tag-row">
              {post.data.tags.map((tag) => <span>{tag}</span>)}
            </div>
            <a class="image-credit" href={post.data.image.creditUrl} rel="noreferrer" target="_blank">{post.data.image.credit}</a>
            <a class="read-link" href={`/blog/${post.id}/`}>Read article</a>
          </article>
        ))}
      </section>
    </main>
    <footer class="site-footer">
      <div>
        <a class="brand" href="/" aria-label="NoArousal home">
          <span class="brand-mark">N</span>
          <span class="brand-text">NoArousal</span>
        </a>
        <p>Public streak. Private discipline. No logs, no triggers, no private recovery data.</p>
      </div>
      <nav aria-label="Footer navigation">
        <a href="/">Home</a>
        <a href="/arena/">Arena</a>
        <a href="/blog/">Blog</a>
        <a href="/quotes/">Quotes</a>
      </nav>
    </footer>
    <script>
      import "../../scripts/app.js";
    </script>
  </body>
</html>
