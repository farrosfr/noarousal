---
import "@fontsource-variable/inter";
import "@fontsource-variable/space-grotesk";
import "../../styles/global.css";
import { getCollection } from "astro:content";
import accountabilityData from "../../data/accountability.json";
import SiteHeader from "../../components/SiteHeader.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import Button from "../../components/Button.astro";
import Tag from "../../components/Tag.astro";
import Icon from "../../components/Icon.astro";

const sortedPosts = (await getCollection("blog")).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const startDateTime = accountabilityData.journeyStart;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="NoArousal articles about no PMO, flatline, recovery habits, and brain technology loops." />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://noa.farros.co/blog/" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0f1318" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="NoArousal" />
    <meta property="og:title" content="NoArousal Blog" />
    <meta property="og:description" content="Articles about no-PMO recovery, flatline, attention, discipline, and PMO technology loops." />
    <meta property="og:url" content="https://noa.farros.co/blog/" />
    <meta name="twitter:card" content="summary" />
    <title>Blog | NoArousal</title>
  </head>
  <body data-start={startDateTime}>
    <SiteHeader />

    <main>
      <section class="blog-hero reveal-on-scroll">
        <p class="badge">Knowledge base</p>
        <h1>Field notes from the streak.</h1>
        <p>
          Short, practical articles on PMO recovery, flatline, attention, and the discipline that comes from keeping your streak public.
        </p>
      </section>

      <section class="blog-grid" aria-label="NoArousal articles">
        {sortedPosts.map((post) => (
          <article class="blog-card card">
            <a class="blog-card-image" href={`/blog/${post.id}/`} aria-label={`Read ${post.data.title}`}>
              <img src={post.data.image.url} alt={post.data.image.alt} loading="lazy" />
            </a>
            <div class="post-meta">
              <Tag tone="gold">{post.data.category}</Tag>
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
              </time>
            </div>
            <h2><a href={`/blog/${post.id}/`}>{post.data.title}</a></h2>
            <p>{post.data.description}</p>
            <div class="tag-row">
              {post.data.tags.map((tag) => <Tag tone="muted">{tag}</Tag>)}
            </div>
            <a class="image-credit" href={post.data.image.creditUrl} rel="noreferrer" target="_blank">Image: {post.data.image.credit}</a>
            <a class="read-link" href={`/blog/${post.id}/`}>
              <span>Read article</span> <Icon name="arrow-right" class="icon" />
            </a>
          </article>
        ))}
      </section>
    </main>
    <footer class="site-footer">
      <div>
        <a class="brand" href="/" aria-label="NoArousal home">
          <span class="brand-mark">N</span>
          <span class="brand-text">NoArousal</span>
        </a>
        <p>Built one refusal at a time.</p>
      </div>
      <nav aria-label="Footer navigation">
        <a href="/">Home</a>
        <a href="/arena/">Arena</a>
        <a href="/blog/">Blog</a>
        <a href="/quotes/">Quotes</a>
      </nav>
    </footer>
    <script id="accountabilityData" type="application/json" set:html={JSON.stringify(accountabilityData)}></script>
    <script>
      import "../../scripts/app.js";
    </script>
  </body>
</html>
