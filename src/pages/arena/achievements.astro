---
import "@fontsource-variable/inter";
import "@fontsource-variable/space-grotesk";
import "../../styles/global.css";
import accountabilityData from "../../data/accountability.json";
import SiteHeader from "../../components/SiteHeader.astro";
import Icon from "../../components/Icon.astro";
import Button from "../../components/Button.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import Tag from "../../components/Tag.astro";
import { streakBadges, refusalBadges, performanceBadges } from "../../data/badges.js";

const startDateTime = accountabilityData.journeyStart;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="NoArousal Hall of Achievements: Complete list of locked and unlocked RPG self-discipline badges ranging from Day 1 to Day 180." />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://noa.farros.co/arena/achievements/" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0f1318" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="NoArousal" />
    <meta property="og:title" content="Achievements | NoArousal" />
    <meta property="og:description" content="View your complete set of unlocked and locked self-discipline achievements up to 180 days." />
    <meta property="og:url" content="https://noa.farros.co/arena/achievements/" />
    <meta name="twitter:card" content="summary" />
    <title>All Achievements | NoArousal</title>
  </head>
  <body data-start={startDateTime}>
    <SiteHeader />

    <main>
      <section class="achievements-hero reveal-on-scroll">
        <p class="badge">Discipline Milestones</p>
        <h1>Hall of <span class="text-gradient">Achievements</span></h1>
        <p class="achievements-intro-sub">
          A comprehensive record of your battles and discipline milestones. Unlocked dynamically as you progress from Day 1 to Day 180.
        </p>
        <div class="achievements-back-btn">
          <Button href="/arena/" variant="ghost" arrow={false}><Icon name="arrow-right" class="icon" style="transform: rotate(180deg);" /> Back to Arena</Button>
        </div>
      </section>

      <div class="achievements-page-layout">
        <section class="achievements-section reveal-on-scroll" aria-label="Streak achievements">
          <SectionHeader
            eyebrow="Days"
            title="Streak Milestones"
            lede="Thirteen milestones along the path from Day 1 to Day 180. The streak gets stronger as it gets older."
          />
          <div class="badges-large-grid">
            {streakBadges.map((badge) => (
              <article class="badge-card locked" id={`badge-${badge.id}`}>
                <div class="badge-icon"><Icon name={badge.icon} /></div>
                <h4>{badge.title}</h4>
                <p>{badge.desc}</p>
                <Tag tone="muted" class="badge-req"><Icon name="calendar" class="icon" />{badge.req}</Tag>
              </article>
            ))}
          </div>
        </section>

        <section class="achievements-section reveal-on-scroll" aria-label="Refusal achievements">
          <SectionHeader
            eyebrow="Refusals"
            title="Refusal Milestones"
            lede="Every urge resisted is damage to the boss. Seven milestones on the way to a hundred."
          />
          <div class="badges-large-grid">
            {refusalBadges.map((badge) => (
              <article class="badge-card locked" id={`badge-${badge.id}`}>
                <div class="badge-icon"><Icon name={badge.icon} /></div>
                <h4>{badge.title}</h4>
                <p>{badge.desc}</p>
                <Tag tone="muted" class="badge-req"><Icon name="swords" class="icon" />{badge.req}</Tag>
              </article>
            ))}
          </div>
        </section>

        <section class="achievements-section reveal-on-scroll" aria-label="Performance achievements">
          <SectionHeader
            eyebrow="Performance"
            title="Combat Performance & Levels"
            lede="The harder numbers: win rate, level, sustained control. Five badges that say you've actually arrived."
          />
          <div class="badges-large-grid">
            {performanceBadges.map((badge) => (
              <article class="badge-card locked" id={`badge-${badge.id}`}>
                <div class="badge-icon"><Icon name={badge.icon} /></div>
                <h4>{badge.title}</h4>
                <p>{badge.desc}</p>
                <Tag tone="muted" class="badge-req"><Icon name="trending-up" class="icon" />{badge.req}</Tag>
              </article>
            ))}
          </div>
        </section>
      </div>
    </main>

    <footer class="site-footer">
      <div>
        <a class="brand" href="/" aria-label="NoArousal home">
          <span class="brand-mark">N</span>
          <span class="brand-text">NoArousal</span>
        </a>
        <p>Built one refusal at a time.</p>
      </div>
      <nav aria-label="Footer navigation">
        <a href="/">Home</a>
        <a href="/arena/">Arena</a>
        <a href="/blog/">Blog</a>
        <a href="/quotes/">Quotes</a>
      </nav>
    </footer>

    <script id="accountabilityData" type="application/json" set:html={JSON.stringify(accountabilityData)}></script>
    <script>
      import "../../scripts/achievements.js";
    </script>
  </body>
</html>
