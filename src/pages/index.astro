---
import "@fontsource-variable/inter";
import "@fontsource-variable/space-grotesk";
import "../styles/global.css";
import accountabilityData from "../data/accountability.json";
import SiteHeader from "../components/SiteHeader.astro";
import Button from "../components/Button.astro";
import SectionHeader from "../components/SectionHeader.astro";
import AssetFrame from "../components/AssetFrame.astro";
import StatChip from "../components/StatChip.astro";
import Tag from "../components/Tag.astro";
import Icon from "../components/Icon.astro";

const startDateTime = accountabilityData.journeyStart;

const categories = [
  {
    id: "costs",
    eyebrow: "What it costs",
    title: "The Price You Pay In The Quiet",
    points: [
      "The secret room shrinks the honest room. Support gets harder to ask for, shame gets louder.",
      "Curated content rewires what intimacy should feel like. Real people stop looking like enough.",
      "Optimized feeds become the comparison. You start editing yourself before you live yourself.",
      "Isolation is both the trigger and the consequence. Alone, tired, device in hand — the loop closes."
    ]
  },
  {
    id: "fighting",
    eyebrow: "What you're fighting",
    title: "The Loop, Not The Lapse",
    points: [
      "It's a loop, not a failure. Cue, craving, response, reward — run it enough times and it runs you.",
      "The chain starts before the choice. Feed open, lights low, alone with a screen — that's move one.",
      "Shame after use becomes the next trigger. The fix becomes the next dose.",
      "The bar isn't \"never.\" The bar is no loss of control, no real-life harm, no quiet despair."
    ]
  },
  {
    id: "beats-it",
    eyebrow: "What beats it",
    title: "Environment Beats Motivation",
    points: [
      "Strip the cues. Block sites, kill autoplay, log out, charge the phone outside the bedroom.",
      "Add friction. Vault your passwords, install blockers, delete the apps, remove the bookmarks.",
      "Replace the slot, not the urge. Sleep, walk, train, write — anything that uses the same hour.",
      "Make it public. Private shame grows. A logged refusal shrinks it. One refusal posted beats ten kept quiet."
    ]
  }
];

const defenses = [
  "Keep the phone out of the bedroom and the bathroom.",
  "Block the high-risk sites before the urge hits, not during it.",
  "Swap late-night scrolling for sleep, a walk, a book, or a workout.",
  "Bring in accountability the moment control starts to slip.",
  "Treat a slip as data: find the trigger, add one rule, keep going."
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="NoArousal: a public PMO-free streak, a personal discipline log, and an evidence-based arena for the loop you're trying to break." />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://noa.farros.co/" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0f1318" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="NoArousal" />
    <meta property="og:title" content="NoArousal" />
    <meta property="og:description" content="Public streak. Private discipline. A no-PMO accountability streak, gamified arena, and the playbook behind the clean day." />
    <meta property="og:url" content="https://noa.farros.co/" />
    <meta name="twitter:card" content="summary" />
    <title>NoArousal</title>
  </head>
  <body data-start={startDateTime}>
    <SiteHeader />

    <main>
      <section class="hero-section">
        <div class="hero-bg" aria-hidden="true"></div>
        <div class="hero-inner reveal-on-scroll">
          <p class="badge">Every clean day is a choice.</p>
          <h1>It's <span class="text-gradient">you vs you</span>.</h1>
          <p class="hero-copy">
            Track the streak. Watch the boss fall. Level up the person you said you'd become.
          </p>

          <article class="streak-panel" aria-live="polite">
            <div class="streak-main">
              <span class="panel-label">The streak</span>
              <strong id="streakDays">0 days</strong>
              <p>You're not waiting for a feeling. You're building one.</p>
            </div>
            <div class="streak-detail">
              <div class="clock-grid" aria-label="Detailed streak time">
                <span><strong id="streakHours">00</strong>hours</span>
                <span><strong id="streakMinutes">00</strong>minutes</span>
                <span><strong id="streakSeconds">00</strong>seconds</span>
              </div>
              <p>Clock started June 6, 2026. It's still running.</p>
            </div>
          </article>

          <section class="accountability-panel" id="accountability" aria-label="Public accountability statistics">
            <div class="accountability-heading">
              <span class="panel-label">Win rate</span>
              <strong id="winRate">100%</strong>
              <p>A clean day is a win. A marked day is a loss. The math is simple.</p>
            </div>
            <div class="accountability-grid">
              <span>
                <strong id="trackedDays">0</strong>
                tracked days
              </span>
              <span>
                <strong id="winDays">0</strong>
                win days
              </span>
              <span>
                <strong id="lossDays">0</strong>
                loss days
              </span>
              <span>
                <strong id="refusalCount">0</strong>
                refusals
              </span>
            </div>
            <p class="accountability-note">Last relapse: <span id="lastRelapse">none logged</span></p>
          </section>

          <!-- Gamified Battle Arena Mini-Widget -->
          <section class="battle-arena-panel reveal-on-scroll" id="battle-arena" aria-label="Inner Battle Status">
            <div class="battle-arena-header">
              <span class="panel-label">Gamified Arena Status</span>
              <h2>It's <span class="text-gradient">you vs you</span></h2>
              <p class="battle-intro">Track your level, shield, and the boss's HP. The math is honest; the work is yours.</p>
            </div>
            
            <div class="battle-arena-content mini-widget">
              <!-- Left side: avatar and basic lvl info -->
              <div class="character-preview-card">
                <img src="/inner_strength_emblem.jpg" alt="Inner Strength Emblem" class="preview-avatar" />
                <div class="preview-info">
                  <h3>Sovereign Self</h3>
                  <div class="preview-level-badge">LVL <span id="charLevel">1</span></div>
                </div>
              </div>

              <!-- Right side: compact progress bars and link -->
              <div class="preview-stats-card">
                <div class="stats-bar-group">
                  <div class="bar-label">
                    <span>XP (Experience)</span>
                    <span id="charXpText">0 / 100 XP</span>
                  </div>
                  <div class="bar-outer">
                    <div class="bar-inner xp-bar" id="charXpBar" style="width: 0%"></div>
                  </div>
                </div>

                <div class="stats-bar-group">
                  <div class="bar-label">
                    <span>Shield Integrity</span>
                    <span id="charShieldText">0%</span>
                  </div>
                  <div class="bar-outer">
                    <div class="bar-inner shield-bar" id="charShieldBar" style="width: 0%"></div>
                  </div>
                </div>

                <div class="stats-bar-group">
                  <div class="bar-label">
                    <span>Shadow Boss HP (Rank <span id="bossRank">1</span>)</span>
                    <span id="bossHpText">100 / 100 HP</span>
                  </div>
                  <div class="bar-outer">
                    <div class="bar-inner boss-hp-bar" id="bossHpBar" style="width: 100%"></div>
                  </div>
                </div>

                <!-- Hidden battleLogs container to prevent app.js from breaking -->
                <ul id="battleLogs" style="display: none;"></ul>

                <div class="widget-cta">
                  <Button href="/arena/" variant="primary" size="md">Enter the arena</Button>
                </div>
              </div>
            </div>
          </section>
        </div>
      </section>

      <section class="intro-section reveal-on-scroll">
        <div>
          <p class="eyebrow">Why this works</p>
          <h2>Visibility beats willpower. Every time.</h2>
        </div>
        <p>
          You don't beat this by gritting harder. You beat it by making the cost visible, the loop obvious, and the environment hostile to the old pattern. Three cards, three tools, no magic.
        </p>
      </section>

      <section class="category-grid" aria-label="PMO risk categories">
        {categories.map((category) => (
          <article class="info-card reveal-on-scroll" id={category.id}>
            <span class="eyebrow">{category.eyebrow}</span>
            <h2>{category.title}</h2>
            <ul>
              {category.points.map((point) => <li>{point}</li>)}
            </ul>
          </article>
        ))}
      </section>

      <section class="defense-section" id="defense">
        <div class="defense-copy reveal-on-scroll">
          <p class="eyebrow">Defense</p>
          <h2>You don't out-think the urge. You out-design it.</h2>
          <p>
            The brain in the moment is not the brain that wrote the rules. Make the rule the wall, not the willpower.
          </p>
        </div>
        <div class="defense-list reveal-on-scroll">
          {defenses.map((defense) => (
            <article>
              <span aria-hidden="true">+</span>
              <p>{defense}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="source-section reveal-on-scroll">
        <p class="eyebrow">Sources</p>
        <h2>Sources and research notes — coming soon.</h2>
      </section>

      <section class="blog-preview reveal-on-scroll">
        <SectionHeader
          eyebrow="Articles"
          title="The playbook behind the streak."
          lede="Flatline, attention, environment design, the technology that makes the habit feel automatic. Read the field notes."
        />
        <Button href="/blog/" variant="secondary">Open the blog</Button>
      </section>
    </main>
    <footer class="site-footer">
      <div>
        <a class="brand" href="/" aria-label="NoArousal home">
          <span class="brand-mark">N</span>
          <span class="brand-text">NoArousal</span>
        </a>
        <p>Built one refusal at a time.</p>
      </div>
      <nav aria-label="Footer navigation">
        <a href="/">Home</a>
        <a href="/arena/">Arena</a>
        <a href="/blog/">Blog</a>
        <a href="/quotes/">Quotes</a>
      </nav>
    </footer>
    <script id="accountabilityData" type="application/json" set:html={JSON.stringify(accountabilityData)}></script>
    <script>
      import "../scripts/app.js";
    </script>
  </body>
</html>
