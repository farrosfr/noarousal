---
export const prerender = false;

import "@fontsource-variable/inter";
import "@fontsource-variable/space-grotesk";
import "../styles/global.css";
import "../styles/game-extras.css";
import { getAccountabilityData, getDynamicFitnessSummary } from "../utils/db";
import { streakBadges, refusalBadges, performanceBadges } from "../data/badges.js";
import SiteHeader from "../components/SiteHeader.astro";
import Icon from "../components/Icon.astro";
import Button from "../components/Button.astro";
import SectionHeader from "../components/SectionHeader.astro";
import AssetFrame from "../components/AssetFrame.astro";
import StatChip from "../components/StatChip.astro";
import Tag from "../components/Tag.astro";

let accountabilityData;
let fitnessSummaryData;
try {
  accountabilityData = await getAccountabilityData(Astro.locals);
  fitnessSummaryData = await getDynamicFitnessSummary(Astro.locals);
} catch (e) {
  console.error("ERROR IN ARENA.ASTRO:", e);
}
const startDateTime = accountabilityData?.journeyStart || "2026-06-06T12:00:00+07:00";

const tabs = [
  { id: "battle", label: "Battle", icon: "swords" },
  { id: "attributes", label: "Attributes", icon: "trending-up" },
  { id: "fitness", label: "Fitness", icon: "dumbbell" },
  { id: "writing", label: "Writing", icon: "book-open" },
  { id: "calendar", label: "Calendar", icon: "calendar" },
  { id: "achievements", label: "Achievements", icon: "award" }
];

const entries = Array.isArray(accountabilityData?.entries) ? accountabilityData.entries : [];
const journeyStart = new Date(startDateTime);
const fitnessPushUps = fitnessSummaryData?.summary?.totalPushUps || 0;
const fitnessRuns = fitnessSummaryData?.summary?.totalRunWalkKm || 0;
const now = new Date();
const streakMs = now - journeyStart;
const trackedDays = Math.max(0, Math.floor(streakMs / 86400000));
const lossPeriods = new Set(
  entries
    .filter((e) => e?.type === "relapse" || e?.result === "loss")
    .map((e) => {
      const ts = new Date(e?.timestamp || e?.relapseTimestamp || e?.date);
      if (Number.isNaN(ts.getTime())) return null;
      const idx = Math.floor((ts.getTime() - journeyStart.getTime()) / 86400000);
      return idx >= 0 && !(idx >= trackedDays) ? idx : null;
    })
    .filter((i) => i !== null)
);
const winDays = Math.max(0, trackedDays - lossPeriods.size);
const winRate = trackedDays > 0 ? Math.round((winDays / trackedDays) * 100) : 100;
const refusalCount = entries.reduce((total, entry) => {
  if (entry?.type === "refuse") return total + 1;
  return total + (Array.isArray(entry?.refusals) ? entry.refusals.length : 0);
}, 0);

const latestRelapse = entries
  .filter((e) => e?.type === "relapse" || e?.result === "loss")
  .map((e) => new Date(e?.timestamp || e?.relapseTimestamp || e?.date))
  .filter((date) => !Number.isNaN(date.getTime()) && !(date.getTime() > now.getTime()))
  .sort((a, b) => b.getTime() - a.getTime())[0];
const streakStartDate = latestRelapse || journeyStart;
const currentStreakMs = now.getTime() - streakStartDate.getTime();
const currentStreakDays = Math.max(0, Math.floor(currentStreakMs / 86400000));

function getAchievementXp(currentStreakDays, refusalCount, winRate, winDays, fitnessPushUps, fitnessRuns) {
  let count = 0;
  
  // Streak Badges
  if (currentStreakDays >= 0) count++;
  if (currentStreakDays >= 3) count++;
  if (currentStreakDays >= 7) count++;
  if (currentStreakDays >= 10) count++;
  if (currentStreakDays >= 14) count++;
  if (currentStreakDays >= 21) count++;
  if (currentStreakDays >= 30) count++;
  if (currentStreakDays >= 45) count++;
  if (currentStreakDays >= 60) count++;
  if (currentStreakDays >= 90) count++;
  if (currentStreakDays >= 120) count++;
  if (currentStreakDays >= 150) count++;
  if (currentStreakDays >= 180) count++;
  if (currentStreakDays >= 200) count++;
  if (currentStreakDays >= 250) count++;
  if (currentStreakDays >= 300) count++;
  if (currentStreakDays >= 365) count++;

  // Refusal Badges
  if (refusalCount >= 1) count++;
  if (refusalCount >= 5) count++;
  if (refusalCount >= 10) count++;
  if (refusalCount >= 20) count++;
  if (refusalCount >= 30) count++;
  if (refusalCount >= 50) count++;
  if (refusalCount >= 100) count++;
  if (refusalCount >= 150) count++;
  if (refusalCount >= 250) count++;
  if (refusalCount >= 500) count++;

  // Performance Badges
  if (winRate >= 95 && winDays >= 5) count++;
  if (winRate === 100 && winDays >= 14) count++;
  if (fitnessPushUps >= 25) count++;
  if (fitnessPushUps >= 250) count++;
  if (fitnessPushUps >= 500) count++;
  if (fitnessPushUps >= 1000) count++;
  if (fitnessPushUps >= 2500) count++;
  if (fitnessPushUps >= 5000) count++;
  if (fitnessPushUps >= 10000) count++;
  if (fitnessRuns >= 10) count++;
  if (fitnessRuns >= 50) count++;
  if (fitnessRuns >= 100) count++;
  if (fitnessRuns >= 250) count++;
  if (fitnessRuns >= 500) count++;

  return count * 50;
}

const achievementXp = getAchievementXp(currentStreakDays, refusalCount, winRate, winDays, fitnessPushUps, fitnessRuns);
const totalXp = winDays * 10 + refusalCount * 25 + fitnessPushUps * 1 + (fitnessRuns || 0) * 10 + achievementXp;
const level = 1 + Math.floor(totalXp / 100);
const xpInLevel = Math.round(totalXp % 100);
const shieldPct = Math.min(100, currentStreakDays * 20);
const willpowerPts = refusalCount + Math.floor(fitnessPushUps / 50);
const fortitudePts = currentStreakDays + Math.floor(fitnessRuns);

const heroShield = `${shieldPct}%`;
const heroXp = `${xpInLevel} / 100`;
const heroRefusals = String(refusalCount);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="NoArousal Battle Arena: Gamified RPG discipline dashboard tracking your Sovereign Self level, XP, shield integrity, and battles against the Shadow Urge." />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="canonical" href="https://noa.farros.co/" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0f1318" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="NoArousal" />
    <meta property="og:title" content="Battle Arena | NoArousal" />
    <meta property="og:description" content="Gamify your self-discipline. Track your RPG attributes, unlock badges, and battle the Shadow Urge." />
    <meta property="og:url" content="https://noa.farros.co/" />
    <meta name="twitter:card" content="summary" />
    <title>Battle Arena | NoArousal</title>
    <!-- Chart.js for premium fitness tracking visualization -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js" defer></script>
  </head>
  <body data-start={startDateTime}>
    <SiteHeader />

    <main>
      <section class="arena-hero reveal-on-scroll">
        <p class="badge">Inner Battle Arena</p>
        <h1>It's <span class="text-gradient">you vs you</span></h1>
        <p class="arena-copy">
          Gamifying self-discipline. Clean days build your shield, urges resisted deal damage to the urge boss, and consistent resolve levels up your Sovereign character.
        </p>
        <div class="hero-stats">
          <StatChip icon="shield" value={heroShield} label="Shield" />
          <StatChip icon="zap" value={heroXp} label="XP" />
          <StatChip icon="target" value={heroRefusals} label="Refusals" tone="positive" />
        </div>
      </section>

      <nav class="tab-bar" data-tab-bar role="tablist" aria-label="Arena sections">
        {tabs.map((tab, i) => (
          <button
            type="button"
            class:list={["tab", { "is-active": i === 0 }]}
            data-tab-trigger={tab.id}
            role="tab"
            aria-selected={i === 0 ? "true" : "false"}
            aria-controls={`tab-panel-${tab.id}`}
            id={`tab-${tab.id}`}
          >
            <Icon name={tab.icon} class="tab-icon" />
            {tab.label}
          </button>
        ))}
      </nav>

      <div class="arena-grid">
        <!-- BATTLE TAB -->
        <section
          class="tab-panel is-active"
          data-tab-panel="battle"
          id="tab-panel-battle"
          role="tabpanel"
          aria-labelledby="tab-battle"
        >
          <section class="combat-screen reveal-on-scroll" aria-label="Active combat arena">
            <div class="character-card">
              <div class="character-avatar-wrapper">
                <img src="/inner_strength_emblem.jpg" alt="Inner Strength Emblem" class="character-avatar" />
                <div class="character-badge-overlay">LVL <span id="charLevel">1</span></div>
              </div>
              <div class="character-info">
                <h3>Sovereign Self</h3>
                <p class="character-class">Sentinel of Will</p>

                <div class="stats-bar-group">
                  <div class="bar-label">
                    <span>XP (Experience)</span>
                    <span id="charXpText">0 / 100 XP</span>
                  </div>
                  <div class="bar-outer">
                    <div class="bar-inner xp-bar" id="charXpBar" style="width: 0%"></div>
                  </div>
                </div>

                <div class="stats-bar-group">
                  <div class="bar-label">
                    <span>Shield Integrity</span>
                    <span id="charShieldText">0%</span>
                  </div>
                  <div class="bar-outer">
                    <div class="bar-inner shield-bar" id="charShieldBar" style="width: 0%"></div>
                  </div>
                </div>
              </div>
            </div>

            <div class="vs-divider">
              <div class="vs-text">VS</div>
              <div class="vs-glow"></div>
            </div>

            <div class="boss-card">
              <div class="character-avatar-wrapper shadow-avatar-border">
                <img src="/shadow_boss.jpg" alt="Shadow Urge Boss" class="character-avatar" />
                <div class="character-badge-overlay shadow-badge-bg">RANK <span id="bossRank">1</span></div>
              </div>
              <div class="character-info">
                <h3 class="boss-name">The Shadow Urge</h3>
                <p class="boss-class">Compulsive Temptation</p>

                <div class="stats-bar-group">
                  <div class="bar-label">
                    <span>Shadow HP</span>
                    <span id="bossHpText">100 / 100 HP</span>
                  </div>
                  <div class="bar-outer">
                    <div class="bar-inner boss-hp-bar" id="bossHpBar" style="width: 100%"></div>
                  </div>
                </div>

                <div class="stats-bar-group">
                  <div class="bar-label">
                    <span>Boss Status</span>
                    <span id="bossStatusText" class="status-indicator alive">ACTIVE</span>
                  </div>
                </div>
              </div>
            </div>
          </section>

          <section class="ninja-simulator-launcher reveal-on-scroll" id="ninja-simulator-launcher" aria-label="Willpower Combat Simulator Launcher">
            <div class="simulator-header">
              <Tag tone="gold"><Icon name="swords" class="icon" />Interactive Minigame</Tag>
              <h2>Willpower Combat <span class="text-gradient">Simulator</span></h2>
              <p class="simulator-intro">A turn-based mini-game simulating the mental fight against urges. Pick your boss, choose a companion, and break the loop in real time.</p>
            </div>
            <div class="launcher-action-container">
              <button type="button" class="btn-launch-simulator" id="btnLaunchSimulator" aria-haspopup="dialog">
                <span class="launch-icon-frame" aria-hidden="true">
                  <Icon name="swords" class="icon" />
                </span>
                <span class="launch-content">
                  <span class="launch-text">Enter Willpower Battle Arena</span>
                  <span class="launch-sub">Choose your boss · Full-screen combat</span>
                </span>
                <span class="launch-arrow" aria-hidden="true">→</span>
              </button>
            </div>
          </section>
        </section>

        <!-- ATTRIBUTES TAB -->
        <section
          class="tab-panel"
          data-tab-panel="attributes"
          id="tab-panel-attributes"
          role="tabpanel"
          aria-labelledby="tab-attributes"
          hidden
        >
          <SectionHeader
            eyebrow="Stats"
            title="RPG Attributes"
            lede="Four numbers that describe who you are in the fight. They feed off each other: willpower wins the moment, fortitude survives it, consistency builds the next one, accuracy decides them all."
          />
          <div class="attributes-grid">
            <article class="attr-card">
              <div class="attr-icon"><Icon name="swords" /></div>
              <div class="attr-details">
                <h4>Willpower <Tag tone="muted">ATK</Tag></h4>
                <p>Based on total urge refusals. Higher willpower weakens temptation faster.</p>
                <div class="attr-value"><span id="attrWillpower">0</span> Pt</div>
              </div>
            </article>

            <article class="attr-card">
              <div class="attr-icon"><Icon name="shield" /></div>
              <div class="attr-details">
                <h4>Fortitude <Tag tone="muted">DEF</Tag></h4>
                <p>Based on current streak length. Keeps your shield fortified at peak urge.</p>
                <div class="attr-value"><span id="attrFortitude">0</span> Pt</div>
              </div>
            </article>

            <article class="attr-card">
              <div class="attr-icon"><Icon name="zap" /></div>
              <div class="attr-details">
                <h4>Consistency <Tag tone="muted">STM</Tag></h4>
                <p>Based on total win (clean) days. Feeds your overall stamina in the long game.</p>
                <div class="attr-value"><span id="attrConsistency">0</span> Pt</div>
              </div>
            </article>

            <article class="attr-card">
              <div class="attr-icon"><Icon name="target" /></div>
              <div class="attr-details">
                <h4>Accuracy <Tag tone="muted">ACC</Tag></h4>
                <p>Based on win rate. Represents focus and precision in decision-making.</p>
                <div class="attr-value"><span id="attrAccuracy">0</span>%</div>
              </div>
            </article>
          </div>
        </section>

        <!-- FITNESS TAB -->
        <section
          class="tab-panel"
          data-tab-panel="fitness"
          id="tab-panel-fitness"
          role="tabpanel"
          aria-labelledby="tab-fitness"
          hidden
        >
          <SectionHeader
            eyebrow="Body"
            title="Physical Resolve & Fitness"
            lede="Real-world physical discipline fuels your mental fortitude. Synced with Strava activities and push-up logs since June 6, 2026."
          />
          <div class="fitness-grid">
            <article class="attr-card fitness-card">
              <div class="attr-icon"><Icon name="activity" /></div>
              <div class="attr-details">
                <h4>Total Run / Walk</h4>
                <p>Builds cardio stamina and endurance. Adds directly to your Fortitude (DEF).</p>
                <div class="attr-value"><span id="fitRunWalkDistance">0.00</span> Km</div>
              </div>
            </article>

            <article class="attr-card fitness-card">
              <div class="attr-icon"><Icon name="dumbbell" /></div>
              <div class="attr-details">
                <h4>Total Push-ups</h4>
                <p>Builds raw physical power. Adds +1 Willpower (ATK) per 50 push-ups.</p>
                <div class="attr-value"><span id="fitPushUpsCount">0</span> Reps</div>
              </div>
            </article>
          </div>

          <div class="fitness-progress-container">
            <!-- Daily Cardio Goal -->
            <div class="fitness-progress-bar-group">
              <div class="bar-label">
                <span>Daily Cardio Goal Progress</span>
                <span id="fitDailyCardioGoalText">0.00 / 2.00 Km</span>
              </div>
              <div class="bar-outer">
                <div class="bar-inner fitness-cardio-bar" id="fitDailyCardioBar" style="width: 0%"></div>
              </div>
            </div>

            <!-- Daily Push-ups Goal -->
            <div class="fitness-progress-bar-group">
              <div class="bar-label">
                <span>Daily Push-ups Goal Progress</span>
                <span id="fitDailyPushGoalText">0 / 200 Reps</span>
              </div>
              <div class="bar-outer">
                <div class="bar-inner fitness-push-bar" id="fitDailyPushBar" style="width: 0%"></div>
              </div>
            </div>

            <!-- Monthly Cardio Goal -->
            <div class="fitness-progress-bar-group">
              <div class="bar-label">
                <span>Monthly Cardio Goal Progress</span>
                <span id="fitMonthlyCardioGoalText">0.00 / 100.00 Km</span>
              </div>
              <div class="bar-outer">
                <div class="bar-inner fitness-cardio-bar" id="fitMonthlyCardioBar" style="width: 0%"></div>
              </div>
            </div>

            <!-- Monthly Push-ups Goal -->
            <div class="fitness-progress-bar-group">
              <div class="bar-label">
                <span>Monthly Push-ups Goal Progress</span>
                <span id="fitMonthlyPushGoalText">0 / 6000 Reps</span>
              </div>
              <div class="bar-outer">
                <div class="bar-inner fitness-push-bar" id="fitMonthlyPushBar" style="width: 0%"></div>
              </div>
            </div>
          </div>

          <!-- Activity History Chart Card -->
          <div class="fitness-chart-card attr-card" style="margin-top: 28px; padding: 24px; display: flex; flex-direction: column; gap: 16px; width: 100%;">
            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px dashed var(--line); padding-bottom: 8px; flex-wrap: wrap; gap: 12px; margin: 0;">
              <h3 style="font-family: 'Space Grotesk Variable', sans-serif; font-weight: 700; font-size: 1.1rem; color: var(--text); margin: 0;">📊 Activity History</h3>
              <div class="chart-filters" style="display: flex; gap: 6px;">
                <button type="button" class="chart-filter-btn" data-range="7">7D</button>
                <button type="button" class="chart-filter-btn is-active" data-range="14">14D</button>
                <button type="button" class="chart-filter-btn" data-range="30">30D</button>
              </div>
            </div>
            <div style="position: relative; height: 320px; width: 100%;">
              <canvas id="fitnessHistoryChart"></canvas>
            </div>
          </div>
        </section>

        <!-- WRITING TAB -->
        <section
          class="tab-panel"
          data-tab-panel="writing"
          id="tab-panel-writing"
          role="tabpanel"
          aria-labelledby="tab-writing"
          hidden
        >
          <SectionHeader
            eyebrow="Intellect"
            title="Intellectual Focus & Writing"
            lede="Writing structures your thoughts and builds mental clarity. Synced with your Substack blog publications since June 6, 2026."
          />
          <div class="fitness-grid">
            <article class="attr-card fitness-card">
              <div class="attr-icon"><Icon name="book-open" /></div>
              <div class="attr-details">
                <h4>Total Written Articles</h4>
                <p>Builds intellectual focus & wisdom. Synced with your Substack blog.</p>
                <div class="attr-value"><span id="fitWritingCount">0</span> Articles</div>
              </div>
            </article>

            <article class="attr-card fitness-card">
              <div class="attr-icon"><Icon name="timer" /></div>
              <div class="attr-details">
                <h4>Monthly Articles Progress</h4>
                <p>Your target is to publish at least 10 articles per month.</p>
                <div class="attr-value"><span id="fitWritingMonthlyCount">0</span> / 10</div>
              </div>
            </article>
          </div>

          <div class="fitness-progress-container">
            <!-- Monthly Writing Goal -->
            <div class="fitness-progress-bar-group">
              <div class="bar-label">
                <span>Monthly Writing Goal Progress</span>
                <span id="fitMonthlyWritingGoalText">0 / 10 Articles</span>
              </div>
              <div class="bar-outer">
                <div class="bar-inner fitness-writing-bar" id="fitMonthlyWritingBar" style="width: 0%"></div>
              </div>
            </div>
          </div>

          <!-- RECENT ARTICLES LIST -->
          <div class="recent-publications-container">
            <h3 class="publications-title" style="margin-top: 36px; margin-bottom: 16px; border-bottom: 1px dashed var(--line); padding-bottom: 8px; font-family: 'Space Grotesk Variable', sans-serif; font-weight: 700; font-size: 1.1rem; color: var(--text);">📝 Recent Publications</h3>
            <div class="publications-list-wrapper" id="writingPublicationsList" style="display: flex; flex-direction: column; gap: 12px; max-height: 480px; overflow-y: auto; padding-right: 4px;">
              <div class="publication-item loading" style="text-align: center; color: var(--text-muted); padding: 32px; border: 1px dashed var(--line); border-radius: 12px; background: rgba(255,255,255,0.015);">Loading publications feed...</div>
            </div>
          </div>
        </section>

        <!-- CALENDAR TAB -->
        <section
          class="tab-panel"
          data-tab-panel="calendar"
          id="tab-panel-calendar"
          role="tabpanel"
          aria-labelledby="tab-calendar"
          hidden
        >
          <SectionHeader
            eyebrow="History"
            title="Willpower Battle Calendar"
            lede="Every day, a verdict. ⚔ marks a victory, 💥 marks a relapse. Maintain the streak to fortify your character."
          />
          <div class="calendar-grid-container">
            <div class="calendar-header-months">
              <span id="calendarMonthName">June 2026</span>
            </div>
            <div class="calendar-days-grid" id="calendarDaysGrid"></div>
            <div class="calendar-legend">
              <span class="legend-item win"><span class="legend-dot win"><Icon name="swords" /></span> Victory Day</span>
              <span class="legend-item loss"><span class="legend-dot loss"><Icon name="x" /></span> Relapse Day</span>
              <span class="legend-item empty"><span class="legend-dot empty"></span> Unlogged / Future</span>
            </div>
          </div>
        </section>

        <!-- ACHIEVEMENTS TAB -->
        <section
          class="tab-panel"
          data-tab-panel="achievements"
          id="tab-panel-achievements"
          role="tabpanel"
          aria-labelledby="tab-achievements"
          hidden
        >
          <SectionHeader
            eyebrow="Trophies"
            title="Discipline Badges"
            lede="Twenty-five milestones on the path from Day 1 to Sovereign Master. Three categories: streak days, urges resisted, performance."
          />

          <div class="badges-section">
            <h3 class="badges-section-title"><Icon name="calendar" class="icon" /> Streak Milestones</h3>
            <div class="badges-grid">
              {streakBadges.map((badge) => (
                <article class="badge-card locked" id={`badge-${badge.id}`}>
                  <div class="badge-icon"><Icon name={badge.icon} /></div>
                  <h4>{badge.title}</h4>
                  <p>{badge.desc}</p>
                  <Tag tone="muted" class="badge-req">{badge.req}</Tag>
                </article>
              ))}
            </div>
          </div>

          <div class="badges-section">
            <h3 class="badges-section-title"><Icon name="swords" class="icon" /> Refusal Milestones</h3>
            <div class="badges-grid">
              {refusalBadges.map((badge) => (
                <article class="badge-card locked" id={`badge-${badge.id}`}>
                  <div class="badge-icon"><Icon name={badge.icon} /></div>
                  <h4>{badge.title}</h4>
                  <p>{badge.desc}</p>
                  <Tag tone="muted" class="badge-req">{badge.req}</Tag>
                </article>
              ))}
            </div>
          </div>

          <div class="badges-section">
            <h3 class="badges-section-title"><Icon name="trending-up" class="icon" /> Performance &amp; Level</h3>
            <div class="badges-grid">
              {performanceBadges.map((badge) => (
                <article class="badge-card locked" id={`badge-${badge.id}`}>
                  <div class="badge-icon"><Icon name={badge.icon} /></div>
                  <h4>{badge.title}</h4>
                  <p>{badge.desc}</p>
                  <Tag tone="muted" class="badge-req">{badge.req}</Tag>
                </article>
              ))}
            </div>
          </div>
        </section>

        <!-- Immersive Fullscreen Simulator (outside tab system) -->
        <div class="ninja-simulator-fullscreen-container" id="ninjaSimulatorFullscreenContainer" style="display: none;">

          <!-- BOSS SELECT SCREEN (shown first) -->
          <div class="boss-select-screen" id="bossSelectScreen" role="dialog" aria-label="Choose your opponent">
            <header class="boss-select-header">
              <Tag tone="gold"><Icon name="swords" class="icon" />SELECT YOUR FIGHT</Tag>
              <h2 class="boss-select-title">Choose your opponent.</h2>
              <p class="boss-select-lede">Five urges. Five levels. Pick the one you're fighting today, or pick the one that scares you most.</p>
            </header>

            <section class="boss-select-section" aria-labelledby="boss-select-bosses-label">
              <h3 class="boss-select-section-title" id="boss-select-bosses-label">
                <Icon name="skull" class="icon" /> Urge Opponent
              </h3>
              <div class="boss-portrait-grid" role="radiogroup" aria-labelledby="boss-select-bosses-label">
                <button type="button" class="boss-portrait-card" data-boss-card="siren" role="radio" aria-checked="false">
                  <div class="boss-portrait-img" data-boss-portrait="siren"></div>
                  <div class="boss-portrait-info">
                    <strong>Boredom Siren</strong>
                    <span class="boss-portrait-meta">Lvl 1 · Chakra Drain</span>
                  </div>
                </button>
                <button type="button" class="boss-portrait-card" data-boss-card="goliath" role="radio" aria-checked="false">
                  <div class="boss-portrait-img" data-boss-portrait="goliath"></div>
                  <div class="boss-portrait-info">
                    <strong>Stress Goliath</strong>
                    <span class="boss-portrait-meta">Lvl 5 · Heavy Hitter</span>
                  </div>
                </button>
                <button type="button" class="boss-portrait-card is-selected" data-boss-card="leviathan" role="radio" aria-checked="true">
                  <div class="boss-portrait-img" data-boss-portrait="leviathan"></div>
                  <div class="boss-portrait-info">
                    <strong>Shadow Leviathan</strong>
                    <span class="boss-portrait-meta">Lvl 10 · Shield Piercer</span>
                  </div>
                </button>
                <button type="button" class="boss-portrait-card" data-boss-card="temptress" role="radio" aria-checked="false">
                  <div class="boss-portrait-img" data-boss-portrait="temptress"></div>
                  <div class="boss-portrait-info">
                    <strong>Malphas, Shadow Temptress</strong>
                    <span class="boss-portrait-meta">Lvl 15 · Will Sapper</span>
                  </div>
                </button>
                <button type="button" class="boss-portrait-card" data-boss-card="archdemon" role="radio" aria-checked="false">
                  <div class="boss-portrait-img" data-boss-portrait="archdemon"></div>
                  <div class="boss-portrait-info">
                    <strong>Dopamine Archdemon</strong>
                    <span class="boss-portrait-meta">Lvl 20 · Desire Overlord</span>
                  </div>
                </button>
              </div>
            </section>

            <section class="boss-select-section" aria-labelledby="boss-select-companions-label">
              <h3 class="boss-select-section-title" id="boss-select-companions-label">
                <Icon name="heart" class="icon" /> Spirit Companion <span class="boss-select-optional">(optional)</span>
              </h3>
              <div class="companion-portrait-grid" role="radiogroup" aria-labelledby="boss-select-companions-label">
                <button type="button" class="companion-portrait-card is-selected" data-companion-card="none" role="radio" aria-checked="true">
                  <span class="companion-portrait-emoji" aria-hidden="true">⛔</span>
                  <strong>None</strong>
                  <span>Solo run</span>
                </button>
                <button type="button" class="companion-portrait-card" data-companion-card="fox" role="radio" aria-checked="false">
                  <span class="companion-portrait-emoji" aria-hidden="true">🦊</span>
                  <strong>Zen Fox</strong>
                  <span>Chakra Restorer</span>
                </button>
                <button type="button" class="companion-portrait-card" data-companion-card="crane" role="radio" aria-checked="false">
                  <span class="companion-portrait-emoji" aria-hidden="true">🦅</span>
                  <strong>Discipline Crane</strong>
                  <span>Debuff Cleanser</span>
                </button>
                <button type="button" class="companion-portrait-card" data-companion-card="wolf" role="radio" aria-checked="false">
                  <span class="companion-portrait-emoji" aria-hidden="true">🐺</span>
                  <strong>Resolve Wolf</strong>
                  <span>Extra Striker</span>
                </button>
                <button type="button" class="companion-portrait-card" data-companion-card="turtle" role="radio" aria-checked="false">
                  <span class="companion-portrait-emoji" aria-hidden="true">🐢</span>
                  <strong>Patience Turtle</strong>
                  <span>Shield Absorber</span>
                </button>
              </div>
            </section>

            <footer class="boss-select-footer">
              <Button href="#" variant="ghost" id="btnBackFromBossSelect" arrow={false}><Icon name="arrow-right" class="icon" style="transform: rotate(180deg);" />Back to arena</Button>
              <Button variant="primary" id="btnBeginBattle" arrow={false}>Begin the fight</Button>
            </footer>
          </div>

          <!-- COMBAT SCREEN (hidden until "Begin") -->
          <div class="combat-screen-wrap" id="combatScreenWrap" style="display: none;">
            <div class="simulator-top-bar">
              <button type="button" class="btn-close-simulator" id="btnCloseSimulator" aria-label="Exit Simulator">
                <span class="close-icon">&times;</span>
                <span class="close-label">Exit Arena</span>
              </button>
            </div>

          <div class="game-board fullscreen-board" id="fullscreenGameBoard">
            <div class="battle-bg-arena">
              <!-- Cinematic Top Boss HP Bar -->
              <div class="boss-top-hp-container" id="bossTopHpContainer">
                <div class="boss-top-info">
                  <span class="boss-top-name boss-name" id="bossTopName">Shadow Demon</span>
                  <span class="boss-top-hp-text" id="gameEnemyHpText">120/120</span>
                </div>
                <div class="boss-top-bar-outer">
                  <div class="boss-top-bar-inner" id="gameEnemyHpBar" style="width: 100%"></div>
                </div>
              </div>

              <div class="rage-vignette" id="rageVignette"></div>

              <div class="focus-ring-overlay" id="focusRingOverlay" style="display: none;">
                <div class="focus-circle-target"></div>
                <div class="focus-circle-outer" id="focusCircleOuter"></div>
                <div class="focus-content">
                  <div class="focus-label">FOCUS BREATH</div>
                  <button type="button" class="btn-focus-action" id="btnFocus">TAP FOCUS!</button>
                </div>
              </div>

              <div class="ninja-character player" id="ninja-player">
                <div class="character-avatar-frame">
                  <img src="/ninja_avatar.jpg" alt="Sovereign Ninja" class="ninja-avatar-img" />
                  <div class="refusal-shield-overlay" id="refusalShieldOverlay"></div>
                  <div class="charge-chakra-overlay" id="chargeChakraOverlay"></div>
                  <div class="enemy-strike-overlay" id="enemyStrikeOverlay"></div>
                </div>
                <div class="character-name">Sovereign Ninja</div>
                <div class="equipped-talismans" id="equippedTalismans">
                  <span class="talisman-slot locked" id="talismanFortress" title="Fortress Amulet (Locked: Requires 3-day streak) - Adds +10% shield absorption">🛡️</span>
                  <span class="talisman-slot locked" id="talismanLotus" title="Lotus Incense (Locked: Requires 7-day streak) - Adds a 2nd Meditation Incense">🕯️</span>
                  <span class="talisman-slot locked" id="talismanWillfire" title="Willfire Blade (Locked: Requires 10 Refusals) - Adds +15% Jutsu Critical hit chance">⚔️</span>
                </div>
                <div class="equipped-companion" id="equippedCompanion" style="display: none;" title="Active Spirit Companion">
                  <span id="companionIcon" class="companion-icon"></span>
                  <span id="companionName" class="companion-name"></span>
                </div>
                <div class="phoenix-buff-badge" id="phoenixBuffBadge" style="display: none;" title="Phoenix Resolve Active: +30% ATK & Starting Shield (Activated within 24h of a relapse)">
                  🔥 Phoenix Resolve
                </div>
                <div class="debuffs-container" id="playerDebuffs"></div>
                <div class="combat-status-bars">
                  <div class="bar-container">
                    <span class="bar-lbl">HP: <span id="gamePlayerHpText">100/100</span></span>
                    <div class="bar-bg"><div class="bar-fill game-hp" id="gamePlayerHpBar" style="width: 100%"></div></div>
                  </div>
                  <div class="bar-container">
                    <span class="bar-lbl">Chakra: <span id="gamePlayerChakraText">50/100</span></span>
                    <div class="bar-bg"><div class="bar-fill game-chakra" id="gamePlayerChakraBar" style="width: 50%"></div></div>
                  </div>
                </div>
                <div class="floating-effect" id="playerDamageFloat"></div>
              </div>

              <div class="vs-banner">VS</div>

              <div class="ninja-character enemy" id="ninja-enemy">
                <div class="character-avatar-frame shadow-avatar-border">
                  <img src="/shadow_avatar.jpg" alt="Shadow Demon" class="ninja-avatar-img shadow-avatar-img" />
                  <div class="strike-overlay" id="strikeOverlay"></div>
                  <div class="will-flame-overlay" id="willFlameOverlay"></div>
                </div>
                <div class="character-name boss-name">Shadow Demon</div>
                <div class="floating-effect" id="enemyDamageFloat"></div>
              </div>
            </div>

            <div class="combat-ticker" id="combatTicker">
              Battle initialized. Choose your action to begin the strike!
            </div>

            <div class="combat-commands" id="combatCommands">
              <button type="button" class="btn-command strike" id="btnStrike" data-cost="0">
                <span class="cmd-icon-frame" aria-hidden="true"><Icon name="sword" class="icon" /></span>
                <span class="cmd-content">
                  <span class="cmd-label">Strike</span>
                  <span class="cmd-desc">Basic physical attack</span>
                </span>
                <span class="cmd-cost"><span class="cmd-cost-key">CHAKRA</span><span class="cmd-cost-val">0</span></span>
              </button>

              <button type="button" class="btn-command jutsu-fire" id="btnFireJutsu" data-cost="20">
                <span class="cmd-icon-frame" aria-hidden="true"><Icon name="flame" class="icon" /></span>
                <span class="cmd-content">
                  <span class="cmd-label">Will Flame</span>
                  <span class="cmd-desc">Deals high damage</span>
                </span>
                <span class="cmd-cost"><span class="cmd-cost-key">CHAKRA</span><span class="cmd-cost-val">20</span></span>
              </button>

              <button type="button" class="btn-command jutsu-heal" id="btnHealJutsu" data-cost="15">
                <span class="cmd-icon-frame" aria-hidden="true"><Icon name="shield" class="icon" /></span>
                <span class="cmd-content">
                  <span class="cmd-label">Refusal Shield</span>
                  <span class="cmd-desc">Heals HP & blocks</span>
                </span>
                <span class="cmd-cost"><span class="cmd-cost-key">CHAKRA</span><span class="cmd-cost-val">15</span></span>
              </button>

              <button type="button" class="btn-command charge" id="btnCharge" data-cost="0">
                <span class="cmd-icon-frame" aria-hidden="true"><Icon name="zap" class="icon" /></span>
                <span class="cmd-content">
                  <span class="cmd-label">Charge Chakra</span>
                  <span class="cmd-desc">Restore 40 Chakra</span>
                </span>
                <span class="cmd-cost"><span class="cmd-cost-key">CHAKRA</span><span class="cmd-cost-val">0</span></span>
              </button>
            </div>

            <div class="combat-items-panel" id="combatItemsPanel">
              <div class="items-panel-title"><Icon name="briefcase" class="icon" />Grounding Inventory <span class="items-panel-sub">Single-use per match</span></div>
              <div class="items-grid">
                <button type="button" class="btn-item-use" id="btnUseColdShower" data-item="coldShower">
                  <span class="item-icon-frame" aria-hidden="true"><Icon name="droplets" class="icon" /></span>
                  <div class="item-details">
                    <span class="item-name">Cold Shower Elixir</span>
                    <span class="item-desc">Heals 50% HP · Disrupts cue loop</span>
                  </div>
                  <span class="item-qty-badge" id="qtyColdShower">1</span>
                </button>

                <button type="button" class="btn-item-use" id="btnUsePushUp" data-item="pushUp">
                  <span class="item-icon-frame" aria-hidden="true"><Icon name="dumbbell" class="icon" /></span>
                  <div class="item-details">
                    <span class="item-name">Push-Up Scroll</span>
                    <span class="item-desc">+40 Chakra · Diverts blood flow</span>
                  </div>
                  <span class="item-qty-badge" id="qtyPushUp">1</span>
                </button>

                <button type="button" class="btn-item-use" id="btnUseMeditation" data-item="meditation">
                  <span class="item-icon-frame" aria-hidden="true"><Icon name="moon" class="icon" /></span>
                  <div class="item-details">
                    <span class="item-name">Meditation Incense</span>
                    <span class="item-desc">Stuns boss 1 turn · Mindfulness</span>
                  </div>
                  <span class="item-qty-badge" id="qtyMeditation">1</span>
                </button>
              </div>
            </div>

            <div class="game-overlay" id="gameOverOverlay" style="display: none;">
              <div class="overlay-box">
                <h3 id="overlayResultTitle">Victory!</h3>
                <p id="overlayResultDesc">The urge has been successfully dispelled.</p>
                <button type="button" class="read-link" id="btnRestartGame">Battle Again</button>
              </div>
            </div>

            <div class="cinematic-victory-overlay" id="cinematicVictoryOverlay" style="display: none;">
              <div class="cinematic-bar top"></div>
              <div class="cinematic-bar bottom"></div>
              <div class="cinematic-art-wrapper">
                <img src="/ninja_victory.jpg" alt="Victory Cutscene Art" class="cinematic-art-img" />
              </div>
              <div class="cinematic-subtitle" id="cinematicSubtitle">
                "At last... the shadow urge dissipates into the light of resolve."
              </div>
              <div class="cinematic-victory-banner" id="cinematicVictoryBanner">
                <div class="banner-tagline">SOVEREIGN RESISTANCE</div>
                <h1 class="victory-title-epic">VICTORY</h1>
              </div>
              <button type="button" class="btn-cinematic-continue" id="btnCinematicContinue">
                Continue to Rewards &rarr;
              </button>
            </div>
          </div><!-- /game-board -->
          </div><!-- /combat-screen-wrap -->

          <!-- RESULTS CARD (shown after cinematic) -->
          <div class="results-card-screen" id="resultsCardScreen" style="display: none;" role="dialog" aria-label="Battle results">
            <div class="results-card">
              <header class="results-card-header">
                <Tag tone="gold"><Icon name="trophy" class="icon" />BATTLE COMPLETE</Tag>
                <h2 class="results-card-title">The urge has fallen.</h2>
                <p class="results-card-sub" id="resultsCardSub">You broke the loop this round.</p>
              </header>
              <div class="results-card-stats">
                <div class="results-stat">
                  <span class="results-stat-key">XP Gained</span>
                  <span class="results-stat-val" id="resultsXpGained">+0</span>
                </div>
                <div class="results-stat">
                  <span class="results-stat-key">Refusals</span>
                  <span class="results-stat-val" id="resultsRefusals">0</span>
                </div>
                <div class="results-stat">
                  <span class="results-stat-key">Outcome</span>
                  <span class="results-stat-val" id="resultsBossName">—</span>
                </div>
                <div class="results-stat">
                  <span class="results-stat-key">Turns</span>
                  <span class="results-stat-val" id="resultsTurns">0</span>
                </div>
              </div>
              <footer class="results-card-footer">
                <Button variant="secondary" id="btnResultsAgain" arrow={false}><Icon name="refresh" class="icon" />Boss select</Button>
                <Button variant="primary" id="btnResultsExit" arrow={false}>Exit arena</Button>
              </footer>
            </div>
          </div>
        </div>
      </div>
    </main>

    <footer class="site-footer">
      <div>
        <a class="brand" href="/" aria-label="NoArousal home">
          <span class="brand-mark">N</span>
          <span class="brand-text">NoArousal</span>
        </a>
        <p>Built one refusal at a time.</p>
      </div>
      <nav aria-label="Footer navigation">
        <a href="/">Home</a>
        <a href="/">Arena</a>
        <a href="/blog/">Blog</a>
        <a href="/quotes/">Quotes</a>
      </nav>
    </footer>

    <script id="accountabilityData" type="application/json" set:html={JSON.stringify(accountabilityData)}></script>
    <script id="fitnessSummaryData" type="application/json" set:html={JSON.stringify(fitnessSummaryData)}></script>
    <script>
      import "../scripts/arena.js";
      import "../scripts/arena-tabs.js";
    </script>
  </body>
</html>
