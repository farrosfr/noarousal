---
const { pathname } = Astro.url;
const navItems = [
  { href: "/", label: "Home" },
  { href: "/arena/", label: "Arena" },
  { href: "/blog/", label: "Blog" },
  { href: "/quotes/", label: "Quotes" }
];

const isActive = (href: string) => {
  if (href === "/") return pathname === "/";
  return pathname === href || pathname.startsWith(href);
};
---

<header class="site-header" data-site-header>
  <a class="brand" href="/" aria-label="NoArousal home">
    <span class="brand-mark" aria-hidden="true">
      <svg viewBox="0 0 40 44" xmlns="http://www.w3.org/2000/svg" class="brand-shield">
        <defs>
          <linearGradient id="shieldFill" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#6366f1" />
            <stop offset="100%" stop-color="#2dd4bf" />
          </linearGradient>
        </defs>
        <path
          d="M20 1.5 L37 7 V22 C37 32 29 39 20 42.5 C11 39 3 32 3 22 V7 Z"
          fill="url(#shieldFill)"
          stroke="#f59e0b"
          stroke-width="1.25"
          stroke-linejoin="round"
        />
        <path
          d="M14 13 L14 32 L17 32 L17 19 L24 32 L27 32 L27 13 L24 13 L24 26 L17 13 Z"
          fill="#f8fafc"
          opacity="0.95"
        />
        <circle cx="20" cy="6" r="1.4" fill="#fbbf24" />
      </svg>
    </span>
    <span class="brand-text">NoArousal</span>
  </a>

  <div class="hud-strip" data-hud role="group" aria-label="Sovereign status">
    <span class="hud-chip" data-hud-level title="Character Level">
      <span class="hud-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="14" height="14"><path fill="currentColor" d="M12 2 4 6 V12 C4 17 7.5 21 12 22 C16.5 21 20 17 20 12 V6 Z M12 4.3 18 7.2 V12 C18 16 15.4 19 12 19.8 C8.6 19 6 16 6 12 V7.2 Z M11 8 H13 V12.6 L16 14.3 L15.2 16 L11 13.6 Z"/></svg>
      </span>
      <span class="hud-value"><span class="hud-label">LVL</span><span data-hud-level-value>1</span></span>
    </span>
    <span class="hud-chip" data-hud-xp title="Experience">
      <span class="hud-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="14" height="14"><path fill="currentColor" d="M13 2 4.1 12.5 11 14.2 10 22 19.5 11 12.5 9.4 Z M11.5 4.7 16.5 5.5 8 15.4 10 16.2 11 19 16 10.5 12 9.4 Z"/></svg>
      </span>
      <span class="hud-value"><span data-hud-xp-value>0</span><span class="hud-label">XP</span></span>
    </span>
    <span class="hud-chip" data-hud-day title="Days Clean">
      <span class="hud-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="14" height="14"><path fill="currentColor" d="M12 2 C7 2 3 6 3 11 C3 16 7 20 12 20 C12.7 20 13.4 19.9 14 19.8 V22 L20 17 L14 12 V14.7 C13.4 14.9 12.7 15 12 15 C8.7 15 6 12.3 6 11 C6 9.7 8.7 7 12 7 C15.3 7 18 9.7 18 11 H21 C21 6 17 2 12 2 Z"/></svg>
      </span>
      <span class="hud-value"><span data-hud-day-value>0</span><span class="hud-label">DAY</span></span>
    </span>
    <span class="hud-chip" data-hud-shield title="Shield Integrity">
      <span class="hud-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="14" height="14"><path fill="currentColor" d="M12 2 4 5 V11 C4 16 7.5 20.5 12 22 C16.5 20.5 20 16 20 11 V5 Z M12 4.2 18 6.4 V11 C18 14.9 15.3 18.5 12 19.8 C8.7 18.5 6 14.9 6 11 V6.4 Z"/></svg>
      </span>
      <span class="hud-value"><span data-hud-shield-value>0</span><span class="hud-label">SHIELD</span></span>
    </span>
  </div>

  <button
    class="menu-toggle"
    type="button"
    aria-label="Open menu"
    aria-controls="primaryNav"
    aria-expanded="false"
    data-menu-toggle
  >
    <span class="blade blade-top"></span>
    <span class="blade blade-mid"></span>
    <span class="blade blade-bot"></span>
  </button>

  <nav class="nav-links" id="primaryNav" aria-label="Primary navigation">
    <span class="menu-label">Menu</span>
    {navItems.map((item) => (
      <a
        href={item.href}
        class:list={["nav-link", { "is-active": isActive(item.href) }]}
        aria-current={isActive(item.href) ? "page" : undefined}
      >
        {item.label}
      </a>
    ))}
  </nav>
</header>

<script>
  import "../scripts/header.js";
</script>
